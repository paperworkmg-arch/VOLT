# Omni-Studio Environment Configuration
# Copy this file to .env and fill in your own values.
# NEVER commit .env or service-account.json to version control.

# === LLM Providers ===
KIMI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=

# === Google OAuth (optional) ===
# GOOGLE_OAUTH_JSON={"omni":{"client_id":"...","client_secret":"...","project_id":"..."}}
# Or use separate env vars:
# GOOGLE_OAUTH_OMNI_CLIENT_ID=
# GOOGLE_OAUTH_OMNI_CLIENT_SECRET=
# GOOGLE_OAUTH_OMNI_PROJECT_ID=
# GOOGLE_OAUTH_SOUNDWAVE_CLIENT_ID=
# GOOGLE_OAUTH_SOUNDWAVE_CLIENT_SECRET=
# GOOGLE_OAUTH_SOUNDWAVE_PROJECT_ID=

# === Google Drive Service Account ===
# Copy your service-account.json to dashboard/data/service-account.json

# === Suno Music (optional) ===
SUNO_SESSION=

# === Scheduler ===
MAX_WORKERS=2
RATE_LIMIT_DELAY=1.0

# === Dashboard Server ===
OMNI_HOST=0.0.0.0
OMNI_PORT=8500
OMNI_DEBUG=true
